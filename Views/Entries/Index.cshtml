@model IReadOnlyList<Entry>
@{
    ViewData["Title"] = "Entries";
}

<div class="page-header">
    <h1>Entries</h1>
    <a class="primary" asp-action="Create">New entry</a>
</div>

@if (Model.Count == 0)
{
    <p>No entries yet.</p>
}
else
{
    <ul class="entry-list">
        @foreach (var entry in Model)
        {
            <li>
                <a asp-action="Details" asp-route-id="@entry.Id">@entry.Title</a>
            </li>
        }
    </ul>
}
