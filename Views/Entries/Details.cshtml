@model EntryDetailsViewModel
@{
    ViewData["Title"] = Model.Entry.Title;
    var history = (Model.Entry.History ?? new List<EntryHistoryRecord>())
        .OrderByDescending(h => h.ChangedAtUtc)
        .ToList();
}

<div class="page-heading">
    <a class="btn btn-ghost" asp-action="Index" style="margin-bottom:4px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        All entries
    </a>
</div>

<div class="detail-card">
    <div class="detail-header">
        <div class="detail-header-icon @(!Model.CanRead ? "detail-header-icon--locked" : "")">
            @if (Model.CanRead)
            {
                @Model.Entry.Title[0].ToString().ToUpper()
            }
            else
            {
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                </svg>
            }
        </div>
        <div class="detail-header-info">
            <h1>@Model.Entry.Title</h1>
            <div class="detail-id">
                Entry #@Model.Entry.Id
                · Owner: <strong>@Model.OwnerUsername</strong>
            </div>
        </div>
        @if (Model.CanRead)
        {
            <div class="detail-header-actions">
                <a class="btn btn-ghost" asp-action="Edit" asp-route-id="@Model.Entry.Id">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Edit
                </a>
            </div>
        }
    </div>
    <div class="detail-body">
        @if (Model.CanRead)
        {
            <div class="detail-label">Stored secret</div>
            <pre class="detail-content">@Model.Entry.Details</pre>
        }
        else
        {
            <div class="access-denied-box">
                <div class="access-denied-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                    </svg>
                </div>
                <div class="access-denied-content">
                    <h3>Access restricted</h3>
                    <p>
                        The contents of this entry are private. It is owned by
                        <strong>@Model.OwnerUsername</strong>.
                        You can request access and the owner will be notified.
                    </p>
                    @if (Model.HasPendingRequest)
                    {
                        <div class="access-requested-notice">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            Request sent — waiting for <strong>@Model.OwnerUsername</strong> to approve.
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-action="RequestAccess" asp-route-id="@Model.Entry.Id" style="margin-top:16px">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.45 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
                                </svg>
                                Request access
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (Model.CanRead && history.Count > 0)
{
    <div class="history-section">
        <details>
            <summary class="history-toggle">
                <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
                Change history
                <span class="history-count">@history.Count @(history.Count == 1 ? "version" : "versions")</span>
            </summary>
            <div class="history-timeline">
                @for (int i = 0; i < history.Count; i++)
                {
                    var record = history[i];
                    var isNewest = i == 0;
                    var isPreHistory = record.ChangedAtUtc == DateTime.MinValue;
                    <div class="history-entry">
                        <div class="history-meta">
                            @if (isNewest)
                            {
                                <span class="history-badge newest">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    Current
                                </span>
                            }
                            <span class="history-badge @(isPreHistory ? "pre-history" : "")">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                @if (isPreHistory)
                                {
                                    <span>Before history tracking</span>
                                }
                                else
                                {
                                    <span>@record.ChangedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</span>
                                }
                            </span>
                            <span class="history-badge">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                @record.ChangedBy
                            </span>
                        </div>
                        @if (record.Title != Model.Entry.Title)
                        {
                            <div class="history-title-change">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;flex-shrink:0"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                                Title was: <strong>@record.Title</strong>
                            </div>
                        }
                        <pre class="history-details-preview">@record.Details</pre>
                    </div>
                }
            </div>
        </details>
    </div>
}
