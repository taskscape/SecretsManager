@model IReadOnlyList<EntryListItemViewModel>
@{
    ViewData["Title"] = "Entries";
    var totalCount = Model.Count;
}

<div class="page-heading">
    <div>
        <h1>All entries</h1>
        <p class="subtitle">@totalCount secret@(totalCount == 1 ? "" : "s") stored securely</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        New entry
    </a>
</div>

@if (totalCount == 0)
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
            </svg>
        </div>
        <h3>No entries yet</h3>
        <p>Create your first entry to start storing secrets securely.</p>
        <a class="btn btn-primary" asp-action="Create" style="margin-top:8px">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            New entry
        </a>
    </div>
}
else
{
    <div class="search-bar">
        <span class="search-bar-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </span>
        <input type="text" id="searchInput" placeholder="Search entries…" autocomplete="off" />
    </div>

    <ul class="entry-list" id="entryList">
        @foreach (var item in Model)
        {
            <li>
                <a class="entry-item @(!item.CanRead ? "entry-item--locked" : "")"
                   asp-action="Details" asp-route-id="@item.Entry.Id"
                   data-title="@item.Entry.Title.ToLower()">
                    <div class="entry-icon @(!item.CanRead ? "entry-icon--locked" : "")">
                        @if (item.CanRead)
                        {
                            @(item.Entry.Title.Length > 0 ? item.Entry.Title[0].ToString().ToUpper() : "?")
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                            </svg>
                        }
                    </div>
                    <div class="entry-info">
                        <div class="entry-title @(!item.CanRead ? "entry-title--locked" : "")">@item.Entry.Title</div>
                        <div class="entry-meta">
                            @if (item.CanRead)
                            {
                                <span>Click to view details</span>
                            }
                            else
                            {
                                <span class="entry-meta--locked">Access restricted · owner: @item.Entry.CreatedBy</span>
                            }
                        </div>
                    </div>
                    <span class="entry-chevron">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </span>
                </a>
            </li>
        }
    </ul>
}

<script>
(function () {
    var input = document.getElementById('searchInput');
    if (!input) return;
    input.addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('#entryList li').forEach(function (li) {
            var item = li.querySelector('.entry-item');
            li.style.display = (!q || item.dataset.title.includes(q)) ? '' : 'none';
        });
    });
})();
</script>
