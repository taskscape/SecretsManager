@model EntryCreateViewModel
@{
    ViewData["Title"] = "New Entry";
}

<div class="panel">
    <h1>New Entry</h1>

    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="field">
            <label asp-for="Title">Entry title</label>
            <input asp-for="Title" />
            <span class="validation" asp-validation-for="Title"></span>
        </div>
        <div class="field">
            <label asp-for="Details">Entry details</label>
            <textarea asp-for="Details" rows="10"></textarea>
        </div>
        <div class="field">
            <label asp-for="Users">Visible to (optional)</label>
            <input asp-for="Users" placeholder="* for all, or comma-separated usernames" />
            <span class="hint">Leave empty for default access, use "*" for all users, or list usernames separated by commas</span>
        </div>
        <div class="actions">
            <button type="submit" class="primary">Create</button>
            <a asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
